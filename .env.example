# https://web3forms.com — create a key; they email it to you.
#
# REQUIRED for email delivery (free tier): browser submit only — add this exact name so Next.js exposes it to the client:
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
#
# Optional: server-side POST only works on Web3Forms paid plans with server IP whitelisting. Otherwise omit.
# WEB3FORMS_ACCESS_KEY=
#
# If neither is set, the form falls back to opening the visitor's mail app (mailto).
