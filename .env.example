# https://web3forms.com — create a key; they email it to you.
#
# REQUIRED for email delivery (free tier): browser submit only — add this exact name so Next.js exposes it to the client:
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
#
# Optional: server-side POST only works on Web3Forms paid plans with server IP whitelisting. Otherwise omit.
# WEB3FORMS_ACCESS_KEY=
#
# If neither is set, the form falls back to opening the visitor's mail app (mailto).
#
# Optional: MacBook GLB under `public/` (defaults to `/models/macbook_air_m2.glb`).
# NEXT_PUBLIC_MACBOOK_GLB=/models/macbook_air_m2.glb
#
# If your texture lands on the wrong surface, set the mesh/node name from the GLB.
# macbook_air_m2 uses Object_4 (glass + wallpaper); keyboard is Object_3 — do not confuse them.
# NEXT_PUBLIC_MACBOOK_SCREEN_MESH=Object_4
#
# LCD map rotation (degrees) — Three.js `texture.rotation` (default for macbook_air is 90).
# NEXT_PUBLIC_MACBOOK_TEX_ROTATION_DEG=90
#
# Vertically flip the map on upload. Defaults to Three.js standard (true). Set false if mirrored.
# NEXT_PUBLIC_MACBOOK_TEX_FLIP_Y=true
#
# Override detected glass aspect (width/height) if the screen still looks stretched.
# NEXT_PUBLIC_MACBOOK_SCREEN_ASPECT=1.6
#
# Texture canvas sizing: default = mesh-matched (eliminates horizontal stretch). Set `hero` for raw 16∶10 (no letterbox but ~8% horizontal compression on this GLB).
# NEXT_PUBLIC_MACBOOK_CANVAS_ASPECT=hero
